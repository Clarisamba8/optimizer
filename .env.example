# ===========================================
# Portfolio Optimizer Environment Variables
# ===========================================

# Database (Local PostgreSQL via Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:54320/optimizer_db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT=10
DATABASE_POOL_RECYCLE=300
DATABASE_POOL_PRE_PING=true
DATABASE_ECHO=false
DATABASE_COMMAND_TIMEOUT=30

# Logging
LOG_LEVEL=INFO

# Ollama (Cloud API)
OLLAMA_BASE_URL=https://ollama.com/v1

# ===========================================
# External API Keys
# ===========================================

# FRED (Federal Reserve Economic Data)
# Get your key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-api-key

# Trading 212 (HTTP Basic auth: Base64(API_KEY:SECRET_KEY) — both required)
# Get your key from: Trading 212 app > Settings > API
# Mode: "live" for real account, "demo" for paper trading account
# IMPORTANT: API keys are environment-scoped — a Demo key only works with mode=demo,
#            a Live key only works with mode=live. You cannot cross-use them.
TRADING_212_API_KEY=your-trading212-api-key
TRADING_212_SECRET_KEY=your-trading212-secret-key
TRADING_212_MODE=live

# Trading Economics
# Get your key at: https://tradingeconomics.com/api
TRADING_ECONOMICS_API_KEY=your-trading-economics-api-key

# Azure OpenAI (for BAML)
OPENAI_KEY=your-azure-openai-key
OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/gpt-4o/chat/completions?api-version=2025-01-01-preview
OPENAI_RESOURCE_NAME=your-resource-name
OPENAI_API_VERSION=2025-01-01-preview
OPENAI_GPT4O_DEPLOYMENT_ID=gpt-4o
OPENAI_GPT5_DEPLOYMENT_ID=gpt-5.2
